APP_NAME="Digitalize with AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Use https in production (e.g. APP_URL=https://yourdomain.com) for OAuth and secure cookies

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For real-time list/record updates (no polling), set BROADCAST_CONNECTION=pusher and:
# PUSHER_APP_ID=your-app-id
# PUSHER_APP_KEY=your-key
# PUSHER_APP_SECRET=your-secret
# PUSHER_APP_CLUSTER=mt1
# Vite bakes these into the frontend at BUILD time — set them when running "npm run build":
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Laravel AI (for digitalize: vision/extract from images)
OPENAI_API_KEY=
# AI HTTP request timeout in seconds (default 600 = 10 min; increase if large images time out)
# AI_REQUEST_TIMEOUT=600

# Amazon Nova API (https://nova.amazon.com/dev/api — get API key there)
NOVA_API_KEY=
# Optional: reasoning_effort=low|medium|high for extended thinking; top_p=0.0-1.0 (default 0.9)
# NOVA_REASONING_EFFORT=
# NOVA_TOP_P=

# Optional: Serper (https://serper.dev) — enables web search in Ask AI (e.g. "how old is X?")
SERPER_API_KEY=

# Google OAuth (Login with Google) — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Branding: show "Powered by X" and use X in copy. Empty = standalone product (no partner branding).
# Hackathon (Amazon Nova): APP_AI_ATTRIBUTION=Amazon Nova
# Product (rebrand):       APP_AI_ATTRIBUTION=  (or omit)
APP_AI_ATTRIBUTION="Amazon Nova"

VITE_APP_NAME="${APP_NAME}"
